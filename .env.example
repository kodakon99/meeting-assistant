# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Required — Groq for Whisper transcription + LLM extraction.
# Get one free at https://console.groq.com
GROQ_API_KEY=

# Required in production — origin of the deployed frontend (Vercel URL).
# Leave blank in local dev; CORS falls back to http://localhost:5173.
CLIENT_URL=

# Optional — server port. Defaults to 3001 locally.
# On Render this is auto-injected; do not set there.
PORT=

# Optional — Notion dispatch.
# Database needs columns: Name, Owner, Deadline, Status, Source meeting.
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Optional — Slack dispatch (per-participant DMs to a channel).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Optional — Email dispatch via Gmail SMTP.
# Use a Google App Password, not your account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=

# Optional — Public app URL used in dispatched email links.
# Defaults to CLIENT_URL.
APP_URL=
