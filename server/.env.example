# Required — Groq API key for Whisper transcription + LLM extraction.
# Get one at https://console.groq.com (free tier: 100k tokens/day).
GROQ_API_KEY=

# Required in production — origin of the deployed frontend.
# In dev this is unset and CORS falls back to http://localhost:5173.
# In production set to e.g. https://your-project.vercel.app
CLIENT_URL=

# Optional — server port. Defaults to 3001 locally.
# Render injects its own PORT automatically; do not set on Render.
PORT=

# Optional — Notion dispatch (creates rows in a Notion database).
# Database needs columns: Name, Owner, Deadline, Status, Source meeting.
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Optional — Slack dispatch (posts per-participant DMs to a channel).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Optional — Email dispatch via Gmail SMTP (use a Google App Password).
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=

# Optional — Public app URL used in dispatched email links. Defaults to CLIENT_URL.
APP_URL=
